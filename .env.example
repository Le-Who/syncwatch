# NEXT_PUBLIC_SUPABASE_URL: URL to the Supabase project
# Required for database persistence of rooms and playback snapshots.
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_ID.supabase.co"

# SUPABASE_SERVICE_ROLE_KEY: The secret service role key (or anon key for testing)
# Required for server.ts to bypass RLS and upsert room state.
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_KEY"

# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"
