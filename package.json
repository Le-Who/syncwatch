{
  "name": "ai-studio-applet",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=\"--no-warnings=DeprecationWarning\" tsx server.ts",
    "build": "next build && tsc --project tsconfig.server.json",
    "start": "cross-env NODE_ENV=production NODE_OPTIONS=\"--no-warnings=DeprecationWarning\" node dist/server.js",
    "lint": "eslint .",
    "clean": "next clean",
    "format": "prettier --write .",
    "prune": "knip",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@next/env": "^16.1.6",
    "@supabase/supabase-js": "^2.98.0",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.21",
    "cookie": "^1.1.1",
    "cross-env": "^10.1.0",
    "fscreen": "^1.2.0",
    "htmlparser2": "^10.1.0",
    "ioredis": "^5.10.0",
    "ipaddr.js": "^2.3.0",
    "jose": "^6.2.0",
    "lucide-react": "^0.577.0",
    "motion": "^12.23.24",
    "next": "^16.1.6",
    "postcss": "^8.5.6",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-player": "^3.4.0",
    "socket.io": "^4.8.3",
    "sonner": "^2.0.7",
    "uuid": "^13.0.0",
    "yt-search": "^2.13.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/cookie": "^0.6.0",
    "@types/fscreen": "^1.0.4",
    "@types/node": "^25.3.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/redlock": "^4.0.8",
    "@types/yt-search": "^2.10.3",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.6",
    "jsdom": "^28.1.0",
    "knip": "^5.85.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "socket.io-client": "^4.8.3",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "minimatch": "^3.1.5"
  }
}
